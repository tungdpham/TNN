# Training configuration
# MODEL_NAME=cifar10_resnet9
# # MODEL_PATH=model_snapshots/cifar10_resnet9
# DATASET_NAME=cifar10
# DATASET_PATH=data/cifar-10-batches-bin

# MODEL_NAME=cifar100_wrn16_8
# DATASET_NAME=cifar100
# DATASET_PATH=data/cifar-100-binary

MODEL_NAME=flash_gpt2_small
# MODEL_NAME=gpt2_small
# MODEL_PATH=model_snapshots/gpt2
DATASET_NAME=open_webtext
DATASET_PATH=data/open-web-text
# # DATASET_PATH=data/open-web-text-1pct

# MODEL_NAME=tiny_imagenet_resnet50
# # MODEL_PATH=model_snapshots/tiny_imagenet_vit
# DATASET_NAME=tiny_imagenet
# DATASET_PATH=data/tiny-imagenet-200/

# MODEL_NAME=mnist_cnn
# # MODEL_PATH=model_snapshots/mnist_cnn
# DATASET_NAME=mnist
# DATASET_PATH=data/mnist

# MODEL_NAME=imagenet100_resnet50
# # MODEL_PATH=model_snapshots/imagenet_resnet50
# DATASET_NAME=imagenet100
# DATASET_PATH=data/imagenet-100

# Coordinator configuration
COORDINATOR_HOST=10.10.0.2
COORDINATOR_PORT=9000

LOCAL_WORKER_POSITION=last # position of the local worker in the pipeline: first, or last
LOCAL_WORKER_HOST=10.10.0.2 # worker that is colocated with the coordinator
LOCAL_WORKER_PORT=8000 

# Worker hosts configuration
WORKER1_HOST=10.10.0.1
WORKER1_PORT=8001

PARTITION_SPLIT_RATIO="1,2"

# more workers can be added similarly, note to add it to the coordinator config as well

# Device configuration
DEVICE_TYPE=GPU

# ROCE config
MASTER_ADDR=10.10.0.2
ROCE_ENABLE_LOCAL_ENDPOINT=1
HCA=mlx5_0
GID_INDEX=5

ROCE_LOCAL_WORKER_DEVICE=mlx5_0
ROCE_LOCAL_WORKER_GID_INDEX=5

ROCE_WORKER1_DEVICE=rocep5s0f0
ROCE_WORKER1_GID_INDEX=3

# =========================
# GPT2 OPENWEBTEXT
# =========================

BATCH_SIZE=16
EPOCHS=20

# ResNet50 ImageNet100: chạy hết epoch + validation + epoch CSV
# TRAIN_MODE=epoch

# GPT-2/OpenWebText: chạy theo step/batch như hiện tại
TRAIN_MODE=batch
MAX_STEPS=20000

# =========================
# Learning rate
# =========================

LR_INITIAL=0.0003

# =========================
# Scheduler
# =========================

SCHEDULER_TYPE=warmup_cosine
WARMUP_STEPS=2000
COSINE_START_LR=0.00015

# cosine scheduler
COSINE_ETA_MIN=0.0

# disable old step scheduler
STEP_LR_EPOCHS=0
STEP_LR_GAMMA=1.0
STEP_LR_STEPS=0

# =========================
# Optimizer
# =========================

ADAMW=1

ADAM_BETA1=0.9
ADAM_BETA2=0.95

ADAM_EPSILON=1e-8

WEIGHT_DECAY=0.1

# =========================
# Pipeline
# =========================

NUM_MICROBATCHES=8
GRADIENT_ACCUMULATION_STEPS=4

TNN_ASYNC_PIPELINE=1

# =========================
# Prefetch
# =========================

# Torch hiện gần như equivalent:
TNN_PREFETCH_DATA=0
TNN_PREFETCH_DEPTH=1

# =========================
# Runtime
# =========================

NUM_THREADS=16

# GPT2 thường không augmentation
TNN_AUGMENTATION=0

# =========================
# GPT2
# =========================

SEQ_LEN=1024

# Logging
LOG_LEVEL=INFO
PROGRESS_PRINT_INTERVAL=10
PROFILER_TYPE=NORMAL
PRINT_LAYER_PROFILING=0
PRINT_LAYER_MEMORY_USAGE=0


# Metric Logging (set to 1 to enable, 0 to disable)
LOG_LOSS=1
LOG_ACCURACY=1
LOG_PRECISION=0
LOG_RECALL=0
LOG_F1_SCORE=0
LOG_PERPLEXITY=1
LOG_TOP_K_ACCURACY=0
LOG_MAE=0
LOG_MSE=0
LOG_RMSE=0

RANK=0
WORLD_SIZE=2
LOCAL_RANK=0
