{
  "epochs": 20,
  "batch_size": 32,
  "max_steps": -1,
  "gradient_accumulation_steps": 1,
  "progress_print_interval": 100,
  "num_threads": 8,
  "profiler_type": "NONE",
  "print_layer_profiling": false,
  "print_layer_memory_usage": false,
  "num_microbatches": 2,
  "device_type": "CUDA",
  "model_name": "imagenet100_resnet50",
  "model_path": "",
  "dataset_name": "imagenet100",
