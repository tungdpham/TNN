{
  "max_steps": 20000,
  "batch_size": 16,
  "gradient_accumulation_steps": 1,
  "progress_print_interval": 10,
  "num_threads": 8,
  "profiler_type": "NONE",
  "print_layer_profiling": false,
  "print_layer_memory_usage": false,
  "num_microbatches": 2,
  "device_type": "CUDA",
  "model_name": "flash_gpt2_small",
  "model_path": "",
  "dataset_name": "open_webtext",
  "dataset_path": "data/open-web-text",
  "io_dtype": "FP32",
  "param_dtype": "FP32",
  "compute_dtype": "FP32",
  "optimizer": {
    "type": "adam",
    "learning_rate": 0.0003,
    "beta1": 0.9,
    "beta2": 0.995,
    "epsilon": 1e-8,
    "weight_decay": 3e-4,
    "decouple_weight_decay": false
  },
  "scheduler": {
    "type": "warmup_cosine_annealing",
    "base_lr": 0.00015,
    "warmup_steps": 2000,
    "T_max": 10,
    "eta_min": 0.0
  },
  "loss": {
    "type": "logsoftmax_crossentropy"
  }
}